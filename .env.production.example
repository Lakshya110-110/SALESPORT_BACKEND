# SalesPort CRM — production env template
#
# Copy to `.env` on the prod host and fill each value. Nothing here is
# committed to source control — the same code runs unchanged; only the
# environment differs.

# --- Core Django ---
SECRET_KEY=change-me-to-a-real-256-bit-secret
DEBUG=False
ALLOWED_HOSTS=api.your-domain.com,your-domain.com

# --- Database ---
DB_ENGINE=mysql
DB_NAME=salesport_crm
DB_USER=salesport
DB_PASSWORD=change-me
DB_HOST=your-rds-host.rds.amazonaws.com
DB_PORT=3306

# --- CORS ---
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://app.your-domain.com

# --- OTP ---
OTP_TTL_SECONDS=300
# NEVER True in production — dev-only convenience.
OTP_RETURN_IN_RESPONSE=False

# --- File storage — Phase 8 flip ---
FILE_STORAGE=s3
AWS_STORAGE_BUCKET_NAME=salesport-crm-prod-media
AWS_S3_REGION_NAME=ap-south-1
# Credentials: OMIT to use the ECS / EC2 IAM role (recommended). Only set
# these in dev or CI where an IAM role isn't available.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Presigned URLs default to 1 hour. Set False + AWS_S3_CUSTOM_DOMAIN if you
# fronted the bucket with CloudFront for public-read files.
AWS_QUERYSTRING_AUTH=True
AWS_QUERYSTRING_EXPIRE=3600
# AWS_S3_CUSTOM_DOMAIN=media.your-domain.com

# --- Django-Q2 ---
# The default `orm` broker uses the DB. Once Phase 10 lands, switch
# to Redis by installing `django-q2[redis]` and populating a REDIS_HOST.
# Q_SYNC=False
