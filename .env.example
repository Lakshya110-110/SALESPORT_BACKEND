# Copy this file to .env and fill in real values. Never commit .env itself
# (it's already in .gitignore) — this file only ever holds placeholders.

# ---- Core ----
SECRET_KEY=change-me-in-production
# Local dev: DEBUG=True. Production: leave unset or set DEBUG=False —
# False is the default if this var is missing entirely.
DEBUG=True
# Production: your real domain(s), comma-separated, e.g.
#   ALLOWED_HOSTS=api.salesport.example.com
# Local dev: leave as * (default).
ALLOWED_HOSTS=*

# ---- Database ----
# Option A — a single connection string (what most PaaS platforms inject
# automatically: Render, Railway, Heroku-likes). If set, everything in
# option B below is ignored.
# DATABASE_URL=mysql://user:password@host:3306/dbname

# Option B — MySQL via individual vars (SalesPort's own AWS/RDS setup).
DB_ENGINE=mysql
DB_NAME=salesport_crm
DB_USER=root
DB_PASSWORD=yourpassword
DB_HOST=127.0.0.1
DB_PORT=3306
# Persistent connection lifetime in seconds (MySQL path only). 0 disables
# persistent connections (a new one per request) — fine locally, costly
# under real production load.
DB_CONN_MAX_AGE=60

# For an instant demo with no MySQL, set:
# DB_ENGINE=sqlite

# ---- Redis (cache + Django-Q2 broker + Socket.IO cross-worker pub/sub) ----
# Local dev: Memurai (Redis-compatible Windows server) at the default below.
# Production: ElastiCache / managed Redis connection string.
REDIS_URL=redis://127.0.0.1:6379/1
# "redis" (default) or anything else to fall back to Django's in-process
# LocMemCache — lets a fresh clone without Redis/Memurai installed still run,
# but Django-Q2 then needs Q_SYNC=True (see below) since its ORM broker
# fallback needs migrations run first.
CACHE_BACKEND=redis
# Run Django-Q2 tasks synchronously in-process instead of via a worker —
# only for local dev without a qcluster process running. Never set this in
# production; background tasks would block the request that queued them.
# Q_SYNC=False

# ---- CORS ----
# Local dev: allow every origin (default True) — the web app usually runs on
# a random localhost port during development.
CORS_ALLOW_ALL_ORIGINS=True
# Production: comma-separated list of exact origins allowed to call this API
# — CORS_ALLOW_ALL_ORIGINS is force-disabled whenever DEBUG=False, so this is
# the only thing that matters there. Include the scheme, no trailing slash.
#   CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://salesport.example.com
CORS_ALLOWED_ORIGINS=

# ---- OTP ----
OTP_TTL_SECONDS=300
# DEV ONLY: echoes the OTP code in the /api/auth/request-otp/ response so you
# can log in without a real SMS gateway. Defaults to True when DEBUG=True,
# False otherwise — a production deploy that forgets this var never leaks a
# code. See crm/otp_delivery.py.
OTP_RETURN_IN_RESPONSE=True
# Comma-separated phone numbers allowed to have their OTP echoed even when
# OTP_RETURN_IN_RESPONSE=True and DEBUG=False — e.g. team test numbers on a
# staging server with real user data. Leave unset for local dev (every
# number echoes, unrestricted). Ignored when OTP_RETURN_IN_RESPONSE=False.
#   OTP_TEST_PHONE_NUMBERS=9876543210,9123456789
OTP_TEST_PHONE_NUMBERS=
# Real SMS provider selector — leave unset until one is actually
# implemented in crm/otp_delivery.py (ProviderOtpDeliveryService is a TODO
# stub today and will raise if this is set without that implementation).
#   OTP_PROVIDER=msg91
OTP_PROVIDER=

# ---- Media / file storage ----
# "filesystem" (default) — local disk under MEDIA_ROOT, served by Django
# only while DEBUG=True (production needs a real static/media story anyway —
# see FILE_STORAGE=s3 below, or front the app with something that serves
# MEDIA_ROOT directly).
FILE_STORAGE=filesystem
# Switch to "s3" to store uploads (proposal PDFs etc.) in S3 instead —
# requires django-storages + boto3 (already in requirements.txt).
# FILE_STORAGE=s3
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_S3_REGION_NAME=ap-south-1
# Omit AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY to use an IAM role / instance
# profile instead (recommended on AWS) — only set them for local/CI testing
# against a real bucket.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Presigned URLs by default (AWS_QUERYSTRING_AUTH=True) so a private bucket
# stays private. Set to False only if fronting with CloudFront + OAC (see
# AWS_S3_CUSTOM_DOMAIN) — presigned URLs defeat CDN caching.
# AWS_QUERYSTRING_AUTH=True
# AWS_QUERYSTRING_EXPIRE=3600
# AWS_S3_CUSTOM_DOMAIN=cdn.salesport.example.com
# AWS_S3_ENDPOINT_URL=   # only for MinIO / R2 / self-hosted S3-compatible

# ---- Security (production only — all gated on DEBUG=False in settings.py) ----
# Set to False only if your load balancer/proxy already fully handles the
# HTTP->HTTPS redirect and a redirect loop shows up otherwise. Defaults True.
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ---- Django-Q2 ----
# See CACHE_BACKEND above — this only matters when CACHE_BACKEND is not
# "redis" (the ORM broker fallback).
# Q_SYNC=False

# ---- Logging ----
DJANGO_LOG_LEVEL=INFO

# ---- Outbound notifications (email/WhatsApp) — stubbed, unused for now ----
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
WHATSAPP_TEMPLATE=
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=
