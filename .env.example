# ---- Core ----
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ---- Database (MySQL = SalesPort's current) ----
DB_ENGINE=mysql
DB_NAME=salesport_crm
DB_USER=root
DB_PASSWORD=yourpassword
DB_HOST=127.0.0.1
DB_PORT=3306

# For an instant demo with no MySQL, set:
# DB_ENGINE=sqlite

# ---- OTP ----
OTP_TTL_SECONDS=300
OTP_RETURN_IN_RESPONSE=True   # DEV ONLY: returns the OTP in the API response

# ---- CORS ----
CORS_ALLOW_ALL_ORIGINS=True
